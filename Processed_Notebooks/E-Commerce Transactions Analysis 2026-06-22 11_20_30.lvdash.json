{
  "datasets": [
    {
      "name": "19ebd68c",
      "displayName": "fact_transactions",
      "config": {
        "version": "1.1",
        "source": "ecommerce.gold.fact_transactions",
        "dimensions": [
          {
            "name": "transaction_id",
            "expr": "source.transaction_id",
            "displayName": "Transaction Id"
          },
          {
            "name": "customer_id",
            "expr": "source.customer_id",
            "displayName": "Customer Id"
          },
          {
            "name": "product_id",
            "expr": "source.product_id",
            "displayName": "Product Id"
          },
          {
            "name": "sales_rep_id",
            "expr": "source.sales_rep_id",
            "displayName": "Sales Rep Id"
          },
          {
            "name": "date_id",
            "expr": "source.date_id",
            "displayName": "Date Id"
          },
          {
            "name": "transaction_date",
            "expr": "source.transaction_date",
            "displayName": "Transaction Date"
          },
          {
            "name": "transaction_month",
            "expr": "DATE_TRUNC('MONTH', source.transaction_date)",
            "displayName": "Month"
          },
          {
            "name": "payment_method",
            "expr": "source.payment_method",
            "displayName": "Payment Method"
          },
          {
            "name": "status",
            "expr": "source.status",
            "displayName": "Status"
          },
          {
            "name": "region",
            "expr": "source.region",
            "displayName": "Region"
          },
          {
            "name": "quantity",
            "expr": "source.quantity",
            "displayName": "Quantity"
          },
          {
            "name": "sales_person_commission_rate",
            "expr": "source.sales_person_commission_rate",
            "displayName": "Sales Person Commission Rate"
          },
          {
            "name": "cost_price",
            "expr": "source.cost_price",
            "displayName": "Cost Price"
          },
          {
            "name": "unit_price",
            "expr": "source.unit_price",
            "displayName": "Unit Price"
          },
          {
            "name": "product_stock_quantity",
            "expr": "source.product_stock_quantity",
            "displayName": "Product Stock Quantity"
          },
          {
            "name": "customers_life_time_value",
            "expr": "source.customers_life_time_value",
            "displayName": "Customers Life Time Value"
          },
          {
            "name": "transaction_amount",
            "expr": "source.transaction_amount",
            "displayName": "Transaction Amount"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "name": "total_transaction_amount",
            "expr": "SUM(source.transaction_amount)",
            "displayName": "Total Transaction Amount"
          },
          {
            "name": "avg_transaction_amount",
            "expr": "AVG(source.transaction_amount)",
            "displayName": "Average Transaction Amount"
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "9b6140b8",
      "displayName": "Analysis",
      "layout": [
        {
          "widget": {
            "name": "monthly_trend",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "19ebd68c",
                  "fields": [
                    {
                      "name": "transaction_month",
                      "expression": "`transaction_month`"
                    },
                    {
                      "name": "measure(total_transaction_amount)",
                      "expression": "MEASURE(`total_transaction_amount`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Monthly Transactions Trend",
